{
  "name": "demo-portal-web",
  "version": "0.0.1",
  "scripts": {
    "ng": "ng",
    "prestart:dev": "node src/environments/set-env.js",
    "prestart:prod": "node src/environments/set-env.js",
    "prestart:build": "node src/environments/set-env.js",
    "start": "ng serve --configuration=development",
    "start:dev": "ng serve --configuration=development",
    "start:prod": "ng serve --configuration=production",
    "build": "npm run prestart:build && ng build --configuration=production",
    "github-build": "ng build --configuration production --base-href '/demo-portal-web/'",
    "github-deploy": "npx angular-cli-ghpages --dir=dist/demo-portal-web/browser --no-silent",
    "watch": "ng build --watch --configuration development",
    "test": "ng test"
  },
  "prettier": {
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^21.2.12",
    "@angular/cdk": "^20.1.3",
    "@angular/common": "^21.2.12",
    "@angular/compiler": "^21.2.12",
    "@angular/core": "^21.2.12",
    "@angular/forms": "^21.2.12",
    "@angular/material": "^20.1.3",
    "@angular/platform-browser": "^21.2.12",
    "@angular/router": "^21.2.12",
    "@tailwindcss/postcss": "^4.1.11",
    "rxjs": "~7.8.0",
    "socket.io-client": "^4.8.1",
    "tailwindcss": "^4.1.11",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.10",
    "@angular/cli": "^21.2.10",
    "@angular/compiler-cli": "^21.2.12",
    "@types/jasmine": "~5.1.0",
    "autoprefixer": "^10.4.21",
    "baseline-browser-mapping": "^2.10.20",
    "colors": "^1.4.0",
    "dotenv": "^17.2.1",
    "jasmine-core": "~5.8.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "postcss": "^8.5.3",
    "typescript": "~5.9.3"
  }
}